{
  "version": 3,
  "rules": [
    {
      "domain": [
        "dns.msftncsi.com",
        "stun.syncthing.net"
      ],
      "domain_suffix": [
        ".srv.nintendo.net",
        ".stun.playstation.net",
        ".xboxlive.com",
        ".turn.twilio.com",
        ".stun.twilio.com",
        ".sslip.io",
        ".nip.io",
        "stun."
      ],
      "domain_regex": [
        "^127([-.]\\d+){3}\\.sslip\\.io$",
        ".*\\.127([-.]\\d+){3}\\.sslip\\.io$",
        "^127([-.]\\d+){3}\\.nip\\.io$",
        ".*\\.127([-.]\\d+){3}\\.nip\\.io$",
        "^stun\\..*"
      ],
      "domain_keyword": [
        "xbox"
      ]
    }
  ]
}
